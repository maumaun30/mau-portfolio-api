# Server
PORT=3001
HOST=0.0.0.0
# Comma-separated CORS allowlist. Empty = allow all (dev only).
ALLOWED_ORIGINS=https://your-portfolio.com
ALLOWED_DOMAIN=your-portfolio.com

# Brevo SMTP
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-smtp-login@smtp-brevo.com
BREVO_SMTP_PASS=your-brevo-smtp-master-password

# Contact form
CONTACT_FROM_EMAIL=contact@yourverifieddomain.com
CONTACT_FROM_NAME=Your Portfolio Name
CONTACT_TO_EMAIL=your-inbox@example.com
